# =============================================================================
# SiteForge — paste your API keys here, then save as ".env.local"
# Copy this file:  cp .env.example .env.local
# =============================================================================

# --- Gemini (recommended) ---
# Get a free key: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# --- OR Vercel AI Gateway (for Claude / gateway-routed Gemini) ---
# Get a key: https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# --- Vercel Sandbox (preview — local dev only) ---
# On Vercel deploy, OIDC auth is automatic. For local dev, either run:
#   vercel link && vercel env pull
# or paste these manually from https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
